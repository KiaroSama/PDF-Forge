# --- PDF Forge ignore rules ---

# Local secret registry (never commit).
/secrets.md

# Private AI explanation file (never commit, even if absent).
explain-AI.md

# Strictly local-only protected entries at any depth. No trailing slash: the
# directory-only form left a *file* of this name in a subdirectory unprotected.
.ignoreme

# Local AI assistant configuration (never commit, at any depth).
.claude/
.kiro/
.codex/
.cursor/
.cline/
.agents/
**/.claude/
**/.kiro/
**/.codex/

# Portable AI working memory and local-only instruction/reference files.
/.ai/
/reference.md
/CLAUDE.md
/AGENTS.md

# Generated knowledge-graph output.
/graphify-out/

# Python caches and build artifacts.
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environment created by Run.ps1.
.venv/

# Runtime logs.
logs/

# Test / coverage artifacts.
.pytest_cache/
.coverage
htmlcov/

# Temporary PDF Forge working files.
.pdfforge_*.tmp

# Project-local scratch folder (watermark previews, etc.).
/temp/

# Project-local native runtimes provisioned on demand (large payload; the
# pinned version/checksum metadata in office_runtime_meta.json IS tracked).
/.tools/

# Record of PDFs this application generated, so folder tools never reprocess
# their own output. Machine-local state, not project source.
/.pdfforge_outputs.json

# OS / editor junk.
Thumbs.db
desktop.ini
.DS_Store
.idea/
.vscode/
